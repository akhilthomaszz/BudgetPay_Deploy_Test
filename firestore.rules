rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'monthlyBudget', 'currency', 'createdAt'])
        && data.keys().size() <= 8
        && data.uid == request.auth.uid
        && data.uid == userId
        && data.email is string && data.email.size() <= 256
        && data.email == request.auth.token.email
        && data.monthlyBudget is number && data.monthlyBudget >= 0
        && data.currency is string && data.currency.size() <= 10
        && data.createdAt == request.time
        && (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() <= 128))
        && (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024));
    }

    function isValidCategory(data, userId) {
      return data.keys().hasAll(['userId', 'name', 'icon', 'color', 'monthlyLimit', 'spent', 'createdAt'])
        && data.keys().size() <= 8
        && data.userId == request.auth.uid
        && data.userId == userId
        && data.name is string && data.name.size() <= 64
        && data.icon is string && data.icon.size() <= 64
        && data.color is string && data.color.size() <= 64
        && data.monthlyLimit is number && data.monthlyLimit >= 0
        && data.spent is number
        && data.createdAt == request.time;
    }

    function isValidTransaction(data, userId) {
      return data.keys().hasAll(['userId', 'amount', 'categoryId', 'categoryName', 'date', 'createdAt'])
        && data.keys().size() <= 12
        && data.userId == request.auth.uid
        && data.userId == userId
        && data.amount is number && data.amount != 0
        && data.categoryId is string && isValidId(data.categoryId)
        && data.categoryName is string && data.categoryName.size() <= 128
        && data.date is timestamp
        // Temporal integrity: date should not be too far in the future (e.g. 1 day grace)
        && data.date.toMillis() <= request.time.toMillis() + (24 * 60 * 60 * 1000)
        && data.createdAt == request.time
        && (
          exists(/databases/$(database)/documents/users/$(userId)/categories/$(data.categoryId)) ||
          exists(/databases/$(database)/documents/users/$(userId)/goals/$(data.categoryId))
        );
    }

    function isValidGoal(data, userId) {
      return data.keys().hasAll(['userId', 'title', 'targetAmount', 'currentAmount', 'deadline', 'createdAt', 'status'])
        && data.keys().size() <= 13
        && data.userId == request.auth.uid
        && data.userId == userId
        && data.title is string && data.title.size() <= 128
        && data.targetAmount is number && data.targetAmount > 0
        && data.currentAmount is number
        && data.deadline is timestamp
        && data.createdAt == request.time
        && data.status in ['active', 'inactive', 'completed']
        && (!('monthlyContribution' in data) || data.monthlyContribution is number)
        && (!('icon' in data) || data.icon is string)
        && (!('color' in data) || data.color is string);
    }

    // 1. User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming(), userId);
      allow update: if isOwner(userId)
        && (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'monthlyBudget', 'currency', 'updatedAt']))
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().updatedAt == request.time;

      // 2. Categories
      match /categories/{categoryId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(categoryId) && isValidCategory(incoming(), userId);
        allow update: if isOwner(userId)
          && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'icon', 'color', 'monthlyLimit', 'spent', 'updatedAt']))
          && incoming().userId == existing().userId
          && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId);
      }

      // 3. Transactions
      match /transactions/{transactionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(transactionId) && isValidTransaction(incoming(), userId);
        allow update: if isOwner(userId)
          && (incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'categoryId', 'categoryName', 'note', 'date', 'receiverName', 'receiverUpi', 'method', 'updatedAt']))
          && incoming().userId == existing().userId
          && incoming().updatedAt == request.time;
        allow delete: if isOwner(userId);
      }

      // 4. Goals
      match /goals/{goalId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(goalId) && isValidGoal(incoming(), userId);
        allow update: if isOwner(userId)
          && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'targetAmount', 'currentAmount', 'monthlyContribution', 'deadline', 'icon', 'color', 'status', 'updatedAt']))
          && incoming().userId == existing().userId
          && incoming().updatedAt == request.time
          // Terminal state locking: if status is 'completed', prevent further updates (unless it's just updating status back or admin)
          && (existing().status != 'completed' || incoming().status == 'completed');
        allow delete: if isOwner(userId);
      }
    }

  }
}
